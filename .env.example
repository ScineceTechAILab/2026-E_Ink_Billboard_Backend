# ============================================
# E-Ink Billboard 后端服务环境变量配置
# 复制此文件为 .env 并填入实际值
# ============================================

# --------------------------------------------
# 基础配置
# --------------------------------------------
# 服务器公网IP（用于生成回调URL等）
SERVER_IP=

# JWT 密钥（务必修改为强密码）
JWT_SECRET=

# --------------------------------------------
# 数据库配置 (PostgreSQL)
# --------------------------------------------
POSTGRES_PASSWORD=

# --------------------------------------------
# Redis 配置
# --------------------------------------------
REDIS_PASSWORD=

# --------------------------------------------
# MinIO 对象存储配置
# --------------------------------------------
MINIO_ACCESS_KEY=
MINIO_SECRET_KEY=

# --------------------------------------------
# EMQX MQTT 配置
# --------------------------------------------
EMQX_USERNAME=admin
EMQX_PASSWORD=

# --------------------------------------------
# 微信小程序配置
# --------------------------------------------
WECHAT_APPID=
WECHAT_SECRET=your_wechat_secret

# --------------------------------------------
# 微信公众号配置
# --------------------------------------------
WX_MP_APPID=
WX_MP_SECRET=your_wx_mp_secret
WX_MP_TOKEN=
WX_MP_AES_KEY=your_43_char_aes_key_here

# --------------------------------------------
# 飞书配置
# --------------------------------------------
FEISHU_APP_ID=
FEISHU_APP_SECRET=your_feishu_app_secret
